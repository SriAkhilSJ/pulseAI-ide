# Copy this file to .env and fill in whichever keys you have (any subset,
# at least one required). .env is git-ignored — never commit real keys.
#
# Get free keys from:
#   Groq:       https://console.groq.com/keys
#   NVIDIA NIM: https://build.nvidia.com (free credits; hosts Z.ai's
#               GLM-5.2 among many others -- NOTE: litellm's nvidia_nim/
#               provider reads NVIDIA_NIM_API_KEY specifically, NOT
#               NVIDIA_API_KEY, even though NVIDIA's own docs/code
#               snippets use that name -- verified directly against
#               litellm's source, see llm_client.py's module docstring)
#   Google AI:  https://aistudio.google.com/apikey
#   Cerebras:   https://cloud.cerebras.ai
#   OpenRouter: https://openrouter.ai/keys
#   Tavily:     https://tavily.com (optional -- web_search fallback if
#               DuckDuckGo is unavailable/blocked; DDG needs no key)

GROQ_API_KEY=
NVIDIA_NIM_API_KEY=
GOOGLE_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
TAVILY_API_KEY=
